{
  "name": "colony-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first memory and coordination for AI coding agents.",
  "license": "MIT",
  "author": "Imdeadpool",
  "homepage": "https://github.com/recodeee/colony",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/recodeee/colony.git"
  },
  "bugs": {
    "url": "https://github.com/recodeee/colony/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./apps/*\" build",
    "check:no-bridge-deps": "bash scripts/check-no-bridge-deps.sh",
    "dev": "pnpm --filter @imdeadpool/colony-cli dev",
    "test": "node --test test/agents-contract.test.js && pnpm -r test",
    "smoke:codex-omx-pretool": "pnpm --filter @colony/hooks test -- test/codex-omx-pretool-smoke.test.ts",
    "smoke:health-repair-loop": "pnpm --filter @imdeadpool/colony-cli test -- health-repair-loop-smoke",
    "typecheck": "pnpm -r typecheck",
    "lint": "node --test test/agents-contract.test.js && pnpm run check:no-bridge-deps && biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "pnpm -r exec rm -rf dist && rm -rf node_modules/.cache",
    "p": "pnpm run release",
    "publish:cli": "bash scripts/publish-cli.sh",
    "publish:cli:dry-run": "bash scripts/publish-cli.sh --dry-run",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
